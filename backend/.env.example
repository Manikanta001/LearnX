# Backend Environment Variables
PORT=5000
NODE_ENV=development

# Firebase Admin SDK - Download serviceAccountKey.json from Firebase Console
# Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="your-private-key"

# OpenAI API Key (optional - for AI hints)
OPENAI_API_KEY=your-openai-api-key

# Judge0 API (optional - for code execution)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-judge0-api-key
JUDGE0_TIMEOUT_MS=8000
JUDGE0_COOLDOWN_MS=120000

# Optional: force local code execution to avoid external API latency during development
FORCE_LOCAL_EXECUTION=false

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Admin login credentials
ADMIN_NAME=admin
ADMIN_EMAIL=admin@dsa.com
ADMIN_LOGIN_PASSWORD=admin123
ADMIN_PRIVATE_PASSWORD=admin@9878

# Email Configuration (for daily reminders)
# Option 1: Gmail (requires App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Option 2: Custom SMTP Server (alternative to Gmail)
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# Daily Reminder Settings
REMINDER_HOUR=9
REMINDER_MINUTE=0

# Legacy support: if only ADMIN_PASSWORD is set, it is used as fallback for
# both ADMIN_LOGIN_PASSWORD and ADMIN_PRIVATE_PASSWORD.
# ADMIN_PASSWORD=admin@9878
